// VID XenServer - Example variable values (copy to windows-xenserver.auto.pkrvars.hcl and fill in)
xenserver_host     = "xs-pool-master.domain.local"
xenserver_username = "root"
xenserver_password = "CHANGEME"
xenserver_sr       = "Local storage"
xenserver_sr_iso   = "XenServer ISOs"
xenserver_network  = "VM Network"

iso_file = "en-us_windows_11_business_editions_version_23h2_x64_dvd.iso"

vm_cpu_count  = 2
vm_mem_size   = 4096
vm_disk_size  = 102400
vm_boot_wait  = "5s"

build_username = "adminst"
build_password = "CHANGEME"

scripts = ["scripts/windows/windows-prepare.ps1"]
inline  = ["Get-EventLog -LogName * | ForEach { Clear-EventLog -LogName $_.Log }"]
